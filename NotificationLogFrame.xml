<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <Frame name="AHNotifyLogFrame" parent="UIParent" inherits="BackdropTemplate" hidden="true" movable="true" enableMouse="true" frameStrata="HIGH">
        <Size x="440" y="380"/>
        <Anchors>
            <Anchor point="CENTER" x="290" y="0"/>
        </Anchors>

        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="AHNotify - Notifications">
                    <Anchors>
                        <Anchor point="TOP" relativePoint="TOP" x="0" y="-18"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <!-- Close button -->
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT" x="-5" y="-5"/>
                </Anchors>
            </Button>

            <!-- Scroll frame -->
            <ScrollFrame name="$parentScrollFrame" inherits="FauxScrollFrameTemplate">
                <Size x="410" y="240"/>
                <Anchors>
                    <Anchor point="TOPLEFT" x="12" y="-68"/>
                </Anchors>
            </ScrollFrame>

            <!-- Clear button -->
            <Button name="$parentClearButton" inherits="UIPanelButtonTemplate" text="Clear All">
                <Size x="80" y="22"/>
                <Anchors>
                    <Anchor point="BOTTOMRIGHT" x="-16" y="12"/>
                </Anchors>
            </Button>
        </Frames>
    </Frame>
</Ui>
