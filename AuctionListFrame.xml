<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <Frame name="AHNotifyListFrame" parent="UIParent" inherits="BackdropTemplate" hidden="true" movable="true" enableMouse="true" frameStrata="HIGH">
        <Size x="540" y="350"/>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parentTitle" inherits="GameFontNormalLarge" text="AHNotify - My Auctions">
                    <Anchors>
                        <Anchor point="TOP" relativePoint="TOP" x="0" y="-18"/>
                    </Anchors>
                </FontString>

                <!-- Column headers -->
                <FontString name="$parentHeaderItem" inherits="GameFontNormalSmall" text="Item">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="40" y="-42"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentHeaderQty" inherits="GameFontNormalSmall" text="Qty">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="260" y="-42"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentHeaderPrice" inherits="GameFontNormalSmall" text="Buyout">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="300" y="-42"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentHeaderTime" inherits="GameFontNormalSmall" text="Time">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="420" y="-42"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentHeaderStatus" inherits="GameFontNormalSmall" text="Status">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="470" y="-42"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <!-- Close button -->
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT" x="-5" y="-5"/>
                </Anchors>
            </Button>

            <!-- Scroll frame -->
            <ScrollFrame name="$parentScrollFrame" inherits="FauxScrollFrameTemplate">
                <Size x="510" y="240"/>
                <Anchors>
                    <Anchor point="TOPLEFT" x="12" y="-56"/>
                </Anchors>
            </ScrollFrame>
        </Frames>
    </Frame>
</Ui>
